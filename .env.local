# MediaMTX Dashboard - Local Environment
# Backend: mediamtx container (localhost:9997 API, localhost:8888 HLS)

# Browser-side: dùng proxy cùng origin để tránh CORS
NEXT_PUBLIC_MEDIAMTX_API_URL=/api/mediamtx

# Server-side: địa chỉ thật của MediaMTX để proxy chuyển tiếp
MEDIAMTX_API_URL=http://localhost:9997

NEXT_PUBLIC_MEDIAMTX_HLS_URL=http://localhost:8888
MTX_WEBRTCADDITIONALHOSTS="localhost"
