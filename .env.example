# MediaMTX Dashboard Environment Variables
# Copy this file to .env and update the values

# Browser-facing MediaMTX API URL.
# The default goes through the dashboard's same-origin API proxy.
NEXT_PUBLIC_MEDIAMTX_API_URL=/api/mediamtx

# Server-side MediaMTX API URL used by the dashboard proxy.
MEDIAMTX_API_URL=http://publisher:9997

# MediaMTX HLS URL (for video streaming)
NEXT_PUBLIC_MEDIAMTX_HLS_URL=http://localhost/hls

# Browser-facing MediaMTX playback, metrics, and pprof URLs.
NEXT_PUBLIC_MEDIAMTX_PLAYBACK_URL=http://localhost:8888
NEXT_PUBLIC_MEDIAMTX_METRICS_URL=http://localhost:9998
NEXT_PUBLIC_MEDIAMTX_PPROF_URL=http://localhost:9999

# MediaMTX WebRTC additional hosts (for local development)
MTX_WEBRTCADDITIONALHOSTS=localhost

# --- Public relay pages (anonymous config/status) ---
# Admin credentials the SERVER uses to reach the MediaMTX Control API on behalf
# of anonymous public pages. Leave unset if MediaMTX auth is disabled. These are
# server-only and never sent to the browser.
# MEDIAMTX_ADMIN_USER=admin
# MEDIAMTX_ADMIN_PASS=adminpass

# Server-side HLS base used by the token-gated public preview proxy. Falls back
# to NEXT_PUBLIC_MEDIAMTX_HLS_URL.
# MEDIAMTX_HLS_URL=http://localhost:8888

# Public hostnames shown to end users in ingest URLs (vMix/OBS). The global
# config only knows bind addresses (e.g. :1935), so set the public ones here.
# NEXT_PUBLIC_MEDIAMTX_RTMP_HOST=rtmp.example.com
# NEXT_PUBLIC_MEDIAMTX_RTMP_ADDRESS=rtmp.example.com:1935
# NEXT_PUBLIC_MEDIAMTX_RTMPS_HOST=rtmp.example.com
# NEXT_PUBLIC_MEDIAMTX_RTMPS_ADDRESS=rtmp.example.com:1936
# NEXT_PUBLIC_MEDIAMTX_SRT_HOST=srt.example.com
# NEXT_PUBLIC_MEDIAMTX_SRT_ADDRESS=srt.example.com:8890

# Signs the short-lived config-session cookie. Set a long random string.
# RELAY_SESSION_SECRET=change-me-to-a-long-random-string

# --- Fallback assets (image/video standby slate) ---
# Public URL of THIS frontend that the MediaMTX backend can reach to fetch
# uploaded fallback assets over HTTP. Required to ACTIVATE image/video fallback
# (text fallback needs none). Example: http://<this-host-ip>:3000
# RELAY_ASSET_BASE_URL=http://192.0.2.10:3000
# Where uploads are stored on disk (mount a volume here in Docker).
# RELAY_ASSET_DIR=/data/relay-assets
# Max upload size in MB (default 100).
# RELAY_ASSET_MAX_MB=100
